# Frontend Supabase configuration
#
# Use the Project URL and a publishable key (`sb_publishable_...`) from
# Supabase. A legacy `anon` key also works during Supabase's transition period.
# Do not put a service_role key, secret key, database password, or access token
# in VITE_* variables.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-legacy-anon-key-here

# Content Moderation (set in Supabase Edge Function secrets)
# Run: supabase secrets set OPENAI_API_KEY=your_openai_key
# The OpenAI Moderation API is FREE and doesn't count against your credits
